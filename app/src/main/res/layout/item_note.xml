<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:background="#E9D7E8"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <TextView
        android:id="@+id/textNoteIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="○"
        android:textColor="#A86A8A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textNoteItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar Android"
            android:textColor="#7E4B66"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textNoteSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Kategori"
            android:textColor="#A57F93"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textNoteTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="09.00"
        android:textColor="#C39CB2"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>