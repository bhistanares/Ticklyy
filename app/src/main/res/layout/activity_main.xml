<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF4E3"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Hyu!"
                    android:textColor="#2F2418"
                    android:textSize="28sp"
                    android:fontFamily="@font/irish_grover"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/textDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kamis, 17 April 2026"
                    android:textColor="#5B4A39"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tickly"
                android:textColor="#2F2418"
                android:textSize="55sp"
                android:fontFamily="@font/kranky_regular"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textMotivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="🌱  Yuk, selesaikan tugasmu hari ini!"
            android:textColor="#5B4A39"
            android:textSize="15sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <!-- TOTAL -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_total"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_total"
                android:gravity="center"
                android:text="▤"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="5"
                android:textColor="#2F2418"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="#2F2418"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SELESAI -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_done"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_done"
                android:gravity="center"
                android:text="✓"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDoneCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="2"
                android:textColor="#2F2418"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selesai"
                android:textColor="#6F761D"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- TERTUNDA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_pending"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_pending"
                android:gravity="center"
                android:text="◴"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textPendingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="33"
                android:textColor="#2F2418"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tertunda"
                android:textColor="#C65C57"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/categoryScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="78dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_all"
                android:gravity="center"
                android:text="Semua"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipPrivate"
                android:layout_width="102dp"
                android:layout_height="42dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_chip_neutral"
                android:gravity="center"
                android:text="Pribadi"
                android:textColor="#2F2418"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipStudy"
                android:layout_width="102dp"
                android:layout_height="42dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_chip_neutral"
                android:gravity="center"
                android:text="Belajar"
                android:textColor="#2F2418"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipShopping"
                android:layout_width="102dp"
                android:layout_height="42dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_chip_shopping"
                android:gravity="center"
                android:text="Belanja"
                android:textColor="#B7BA3F"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/sectionHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/categoryScroll">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tugas Hari Ini"
            android:textColor="#2F2418"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSeeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lihat semua  →"
            android:textColor="#77791E"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/listNotes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sectionHeader" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:background="#6B5138"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/btnSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="#FFFFFF"
                android:textSize="34sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cari"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnAddNote"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_circle_add"
                android:gravity="center"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="40sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah"
                android:textColor="#C6C646"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♙"
                android:textColor="#FFFFFF"
                android:textSize="34sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>